PORT=3000

# Postgres (step 5: docker-compose service name as host once containerized)
DATABASE_URL=postgres://sweetdreams:sweetdreams@localhost:5432/sweetdreams

# Stripe (step 7: test-mode keys from the Dashboard)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Admin auth (step 4). Real logins live in the admin_users table now (add
# more from the dashboard's Team panel), not env vars - these two are only a
# one-time bootstrap, read by `npm run migrate` to seed the first admin row
# the first time admin_users is empty. Safe to leave set after that; they're
# ignored once at least one row exists. Generate the hash with:
#   npm run hash-password -- 'your-real-password'
# docker-compose interpolates $ in env_file values, and bcrypt hashes are full
# of $ (e.g. $2a$12$...), so double every $ to $$ here or compose silently
# mangles the hash and login breaks with no error. Not needed when running
# the app directly with `npm run dev` (dotenv doesn't interpolate).
ADMIN_EMAIL=owner@sweetdreamsrvrentals.com
ADMIN_PASSWORD_HASH=

# Notify (step 14)
NOTIFY_TO_EMAIL=info@sweetdreamsrvrentals.com

# Real email delivery (step 13, part 2) via Resend - https://resend.com/api-keys
RESEND_API_KEY=re_...
# Works out of the box with Resend's shared onboarding domain. Once
# sweetdreamsrvrentals.com is verified as a sending domain in Resend (adding
# SPF/DKIM records in Wix's DNS panel - a deliberate follow-up, not required
# to start sending), switch this to something like:
#   MAIL_FROM=Sweet Dreams RV Rentals <info@sweetdreamsrvrentals.com>
MAIL_FROM=Sweet Dreams RV Rentals <onboarding@resend.dev>
MAIL_REPLY_TO=info@sweetdreamsrvrentals.com

# Real driving-distance delivery pricing for an unlisted ("Other")
# address - Google Distance Matrix API. Create a key at
# console.cloud.google.com (a project with billing enabled, "Distance
# Matrix API" turned on), restrict it to that API only. Without this set,
# an unlisted address falls back to "confirm with quote" instead of an
# automatic fee - the site still works, just without this one feature.
GOOGLE_MAPS_API_KEY=
