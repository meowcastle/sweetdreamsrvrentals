PORT=3000

# Postgres (step 5: docker-compose service name as host once containerized)
DATABASE_URL=postgres://sweetdreams:sweetdreams@localhost:5432/sweetdreams

# Stripe (step 7: test-mode keys from the Dashboard)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Admin auth (step 4). Generate the hash with:
#   npm run hash-password -- 'your-real-password'
# docker-compose interpolates $ in env_file values, and bcrypt hashes are full
# of $ (e.g. $2a$12$...), so double every $ to $$ here or compose silently
# mangles the hash and login breaks with no error. Not needed when running
# the app directly with `npm run dev` (dotenv doesn't interpolate).
ADMIN_EMAIL=owner@sweetdreamsrvrentals.com
ADMIN_PASSWORD_HASH=

# Notify (step 14)
NOTIFY_TO_EMAIL=info@sweetdreamsrvrentals.com
