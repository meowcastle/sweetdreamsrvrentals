# Read by docker-compose (not by the app itself, that's backend/.env).
# Copy to .env before running `docker compose up`.

POSTGRES_USER=sweetdreams
POSTGRES_PASSWORD=change-me
POSTGRES_DB=sweetdreams

# Local dev default is fine as-is. On the Synology, point this at
# /volume1/docker/sweetdreams so Hyper Backup can cover the Postgres data.
DATA_DIR=./data

# scripts/backup-db.sh (step 6): where nightly pg_dump backups land, and how
# long to keep them. Defaults to a "backups" folder next to DATA_DIR, so on
# the Synology it ends up in the same Hyper Backup-covered shared folder.
# BACKUP_DIR=/volume1/docker/sweetdreams/backups
# RETENTION_DAYS=30

# Only needed if 5432 is already taken on the host (e.g. another package's
# own Postgres). The app always talks to Postgres over the compose network,
# never through this published port, so it's safe to change.
# POSTGRES_HOST_PORT=5433

# Only needed if 3000 is already taken on the host (e.g. another app already
# running there). If you change this, also set API_PORT to match when running
# scripts/dev-server.js, and this same value in scripts/dev-tunnel.sh's health
# check picks it up automatically from this file.
# APP_HOST_PORT=3001

# Only needed if 4321 is already taken on the host. This is the "web"
# service's published port - the one place that serves the whole site
# (static files + proxied API) under one origin, and what a reverse proxy
# or Cloudflare Tunnel should point at.
# WEB_HOST_PORT=4322

# Cloudflare Tunnel (outbound-only, no port forwarding needed). Get this from
# the Cloudflare dashboard: Networking > Tunnels > sweetdreams-nas > the
# docker run command's --token value. Real secret - only set in .env, never
# committed. Only meaningful to run on the NAS, the intended long-term host -
# see the cloudflared service's own comment in docker-compose.yml.
CLOUDFLARE_TUNNEL_TOKEN=
